{
  "compilerOptions": {
    "target": "ES2022",

    "module": "NodeNext",
    "moduleResolution": "NodeNext",

    "rootDir": ".",
    "outDir": "./dist",

    "types": ["node"],

    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,

    "sourceMap": true,
    "forceConsistentCasingInFileNames": true
  },

  "include": [
    "src/**/*",
    "prisma.config.ts",
    "prisma/**/*.ts"
  ],

  "exclude": [
    "node_modules",
    "dist"
  ]
}